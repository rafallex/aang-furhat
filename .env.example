# Copy to .env and edit, OR just set these in your shell before running.
# (Aang reads plain environment variables; nothing here is required except an
#  LLM key if you want real conversation.)

# ---- Robot ----
FURHAT_HOST=192.168.1.107
# FURHAT_KEY=...                 # only if your robot requires an auth key

# ---- Brain (Groq is free: https://console.groq.com/keys) ----
AANG_BRAIN=groq
# GROQ_API_KEY=gsk_...           # set in your shell; never commit a key
AANG_MODEL=llama-3.3-70b-versatile
# Alternative provider:
# AANG_BRAIN=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# AANG_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ---- Look & voice (override only if you want to) ----
AANG_FACE=adult - Aang4
AANG_FACE_AVATAR=adult - Aang4Avatar
AANG_VOICE=Justin-Neural (en-US) - Amazon Polly
# Fallback TTS voice if the deep Avatar voice FX is unavailable (the deep Avatar voice itself uses AANG_FX_VOICE):
AANG_VOICE_AVATAR=ChristopherNeural (en-US) - Microsoft Azure
AANG_VOLUME=60
AANG_VOLUME_AVATAR=72              # a touch louder in the Avatar State

# ---- Avatar State behaviour ----
AANG_AVATAR_TIMEOUT=25            # seconds before the Avatar State burns out on its own
AANG_PTT=0   # 0 = hands-free open mic (default); 1 = push-to-talk (press space)
# AANG_FX_VOICE=en-US-ChristopherNeural   # edge-tts voice the deep Avatar voice is built from
AANG_AVATAR_FX=1   # 1 = render the deep voice on this PC and stream to the robot (needs LAN/Ethernet); 0 = robot native deep voice
# AANG_FX_PORT=8079              # HTTP port the deep-voice WAVs are served on; must be reachable on the LAN (separate from AANG_SFX_PORT)
# AANG_FX_DIR=                   # where rendered WAVs are written (default: %TEMP%\aang_fx)

# ---- Avatar State wind SFX (served from this PC to the robot) ----
AANG_SFX=1
# AANG_SFX_HOST=192.168.1.33     # autodetected if left blank
AANG_SFX_PORT=8077

# ---- Installing the custom face (tools/import_aang_face.py only) ----
# AANG_CHAR_NAME=Aang4           # character name the face pack installs/selects as
